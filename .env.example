# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# AI Provider ("openai" veya "gemini")
AI_PROVIDER=openai
AI_API_KEY=your-ai-api-key
AI_MODEL=gpt-4o

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_ACCOUNT_ID=your-instagram-account-id

# Instagram OAuth (Facebook Developer Console'dan)
INSTAGRAM_CLIENT_ID=your-facebook-app-id
INSTAGRAM_CLIENT_SECRET=your-facebook-app-secret
INSTAGRAM_REDIRECT_URI=http://localhost:8080/auth/instagram/callback

# API Server
API_PORT=8080
