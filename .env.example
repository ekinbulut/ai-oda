# Supabase
SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_ANON_KEY=placeholder-anon-key
SUPABASE_SERVICE_KEY=placeholder-service-key

# AI Provider
AI_PROVIDER=openai
AI_API_KEY=placeholder
AI_MODEL=gpt-4o

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=placeholder
INSTAGRAM_ACCOUNT_ID=placeholder

# Instagram OAuth
INSTAGRAM_CLIENT_ID=placeholder-client-id
INSTAGRAM_CLIENT_SECRET=placeholder-client-secret
